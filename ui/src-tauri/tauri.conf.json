{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../frontend",
    "distDir": "../frontend"
  },
  "package": {
    "productName": "agent-framework",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true },
      "window": { "all": false, "close": true, "hide": true, "show": true, "maximize": true, "minimize": true, "unmaximize": true, "unminimize": true, "startDragging": true, "setSize": true, "setPosition": true, "setTitle": true, "setFocus": true }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.agentframework.dev",
      "icon": [
        "icons/icon.ico"
      ]
    },
    "security": { "csp": null },
    "windows": [
      {
        "label": "main",
        "title": "Agent Framework",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ]
  }
}
